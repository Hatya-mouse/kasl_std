func min(a: Int, b: Int) -> Int {
    return Builtin.imin(a, b)
}

func max(a: Int, b: Int) -> Int {
    return Builtin.imax(a, b)
}

func clamp(x: Int, min_val: Int, max_val: Int) -> Int {
    return Builtin.imax(min_val, Builtin.imin(x, max_val))
}

func abs(value: Int) -> Int {
    return Builtin.iabs(value)
}

func sgn(value: Int) -> Int {
    return Builtin.isgn(value)
}
